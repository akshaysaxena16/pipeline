materialize_render_env.sh
#!/usr/bin/env bash
set -euo pipefail

# Build render-vars JSON for ${KEY} substitution in workflow bundles.
#
# Preferred (GitHub Environment variables on cert / prod):
#   Job must set:  environment: cert   (or prod)
#   Workflow step:
#     env:
#       VARS_JSON: ${{ toJson(vars) }}
#     run: scripts/materialize_render_env.sh cert
#
# Legacy (single JSON repository secret) — still supported:
#   env:
#     SFN_RENDER_VARS_JSON: ${{ secrets.SFN_RENDER_VARS_CERT }}
#   run: scripts/materialize_render_env.sh cert
#
# Output: SFN_RENDER_ENV_FILE (default /tmp/sfn-render-env-<env>.json) with ENV=<env> set.

ENV_NAME="${1:-}"

if [[ -z "$ENV_NAME" ]]; then
  echo "Usage: VARS_JSON='<json>' $0 <cert|prod>" >&2
  echo "   or: SFN_RENDER_VARS_JSON='<json>' $0 <cert|prod>" >&2
  exit 2
fi

OUT="${SFN_RENDER_ENV_FILE:-/tmp/sfn-render-env-${ENV_NAME}.json}"

if [[ -n "${VARS_JSON:-}" ]]; then
  printf '%s' "$VARS_JSON" | jq -e . > "${OUT}.tmp"
elif [[ -n "${SFN_RENDER_VARS_JSON:-}" ]]; then
  printf '%s' "$SFN_RENDER_VARS_JSON" | jq -e . > "${OUT}.tmp"
else
  echo "Missing VARS_JSON (from GitHub Environment variables: toJson(vars)) or SFN_RENDER_VARS_JSON" >&2
  exit 2
fi

# GitHub Environment variables are strings; coerce JSON array/object strings for ASL.
# Always set ENV from the deployment target (branch / workflow input), not from a variable.
jq --arg env "$ENV_NAME" '
  with_entries(
    .value |= if type == "string" then
      (. as $s | try ($s | fromjson) catch $s)
    else
      .
    end
  )
  | . + {ENV: $env}
' "${OUT}.tmp" > "$OUT"
rm -f "${OUT}.tmp"

echo "Wrote render env: $OUT (ENV=$ENV_NAME, keys=$(jq 'keys | length' "$OUT"))"

# Warn on placeholders in git that have no value in this environment.
if [[ -d stepfunctions/workflows ]]; then
  mapfile -t PLACEHOLDERS < <(
    grep -rohE '\$\{[A-Z][A-Z0-9_]*\}' stepfunctions/workflows 2>/dev/null \
      | sed 's/^\${//;s/}$//' \
      | grep -v '^ENV$' \
      | sort -u \
      || true
  )
  missing=()
  for key in "${PLACEHOLDERS[@]}"; do
    [[ -z "$key" ]] && continue
    val="$(jq -r --arg k "$key" '.[$k] // empty' "$OUT")"
    if [[ -z "$val" || "$val" == "null" ]]; then
      missing+=("$key")
    fi
  done
  if (( ${#missing[@]} > 0 )); then
    echo "ERROR: GitHub Environment is missing variable(s) for placeholder(s) used in stepfunctions/workflows:" >&2
    printf '  - %s\n' "${missing[@]}" >&2
    exit 1
  fi
fi
